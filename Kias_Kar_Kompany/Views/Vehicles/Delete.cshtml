@model Kias_Kar_Kompany.Models.Vehicle

@{
    ViewData["Title"] = "Delete Vehicle";
}

<h1>Delete Vehicle</h1>

<h3>Are you sure you want to delete this?</h3>

<div>
    <h4>Vehicle</h4>
    <hr />

    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.VehicleName)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.VehicleName)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.VehicleModel)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.VehicleModel)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.VehiclePrice)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.VehiclePrice)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.VehicleType)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.VehicleType)
        </dd>

        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.VehicleImageURL)
        </dt>
        <dd class="col-sm-10">
            @Html.DisplayFor(model => model.VehicleImageURL)
        </dd>
    </dl>

    <form asp-action="Delete">
        <input type="hidden" asp-for="VehicleId" />

        <input type="submit" value="Delete" class="btn btn-danger" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>